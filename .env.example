# Environment mode
NUXT_PUBLIC_MODE=development

# AT Protocol configuration
NUXT_PUBLIC_ATPROTO_SERVICE=https://bsky.social
NUXT_PUBLIC_ATPROTO_REPO=replace-with-your-bsky-repo.bsky.social

# Social links
NUXT_PUBLIC_SOCIAL_GITHUB=replace-with-your-github-username
NUXT_PUBLIC_SOCIAL_BLUESKY=replace-with-your-bluesky-handle
NUXT_PUBLIC_SOCIAL_LINKEDIN=replace-with-your-linkedin-username

# Optional, only if you want to track website usage
UMAMI_SCRIPT_SRC=https://umami.example.com/script.js
UMAMI_WEBSITE_ID=1234567890

# Nitro cache (ATProto blog + Bluesky avatar)
# TTL in seconds (defaults match nuxt.config if unset)
NUXT_CACHE_BLOG_TTL_SECONDS=43200
NUXT_CACHE_AVATAR_TTL_SECONDS=86400

# Secret for POST /api/cache/purge (header x-cache-token)
NUXT_CACHE_PURGE_TOKEN=replace-with-a-long-random-secret
